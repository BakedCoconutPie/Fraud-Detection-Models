   "type": "paste",
   "text": "float angle = 0;\n\nfinal int maxiterations = 100;\n\nint[] colorsRed = new int[maxiterations];\nint[] colorsGreen = new int[maxiterations];\nint[] colorsBlue = new int[maxiterations];\n\nvoid setup() {\n  pixelDensity(1);\n  size(640, 360);\n  colorMode(HSB, 1);\n\n  for (int n = 0; n < maxiterations; n++) {\n\n    float hu = sqrt(n / (float)maxiterations);\n    int col = color(hu, 1, 0.59);\n    colorsRed[n] = red(col);\n    colorsGreen[n] = green(col);\n    colorsBlue[n] = blue(col);\n  }\n}\n\nvoid draw() {\n\n  float ca = cos(angle * 3.213); //sin(angle);\n  float cb = sin(angle);\n\n  angle += 0.02;\n\n  background(255);\n\n  float w = 5;\n  float h = (w * height) / width;\n\n  float xmin = -w / 2;\n  float ymin = -h / 2;\n\n  loadPixels();\n\n  float xmax = xmin + w;\n\n  float ymax = ymin + h;\n\n  float dx = (xmax - xmin) / width;\n  float dy = (ymax - ymin) / height;\n\n  float y = ymin;\n  for (int j = 0; j < height; j++) {\n    float x = xmin;\n    for (int i = 0; i < width; i++) {\n\n      float a = x;\n      float b = y;\n      int n = 0;\n      while (n < maxiterations) {\n        float aa = a * a;\n        float bb = b * b;\n\n        if (aa + bb > 4.0) {\n          break;\n        }\n        float twoab = 2.0 * a * b;\n        a = aa - bb + ca;\n        b = twoab + cb;\n        n++;\n      }\n\n      int pix = (i + j * width) * 4;\n      if (n == maxiterations) {\n        pixels[pix + 0] = 0;\n        pixels[pix + 1] = 0;\n        pixels[pix + 2] = 0;\n      } else {\n        pixels[pix + 0] = colorsRed[n];\n        pixels[pix + 1] = colorsGreen[n];\n        pixels[pix + 2] = colorsBlue[n];\n      }\n      x += dx;\n    }\n    y += dy;\n  }\n  updatePixels();\n  println(frameRate);\n}",
