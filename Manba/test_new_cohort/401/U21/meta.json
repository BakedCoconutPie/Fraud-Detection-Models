height); sz[i]=width; }\n    float px=map(sx[i]/sz[i],0,1,0,width), py=map(sy[i]/sz[i],0,1,0,height);\n    float r=map(sz[i],0,width,8,0);\n    fill(255); noStroke(); ellipse(px,py,r,r);\n  }\n}","T":94217,"N":"uuid-a3f2 external source"}]}